#!/bin/bash
exec </dev/tty1 >/dev/tty1 2>&1

dmesg -n 1 2>/dev/null
echo 0 > /proc/sys/kernel/printk 2>/dev/null || true

B=$'\033[1m'; C=$'\033[1;36m'; BL=$'\033[1;34m'; G=$'\033[1;32m'
Y=$'\033[1;33m'; R=$'\033[1;31m'; D=$'\033[2m'; E=$'\033[0m'

# Detect terminal size — clamp to >=80 so draw_wide always fires on tty1
COLS=$(tput cols  2>/dev/null); [[ "$COLS" =~ ^[0-9]+$ ]] || COLS=80; [[ $COLS -lt 80 ]] && COLS=80
ROWS=$(tput lines 2>/dev/null); [[ "$ROWS" =~ ^[0-9]+$ ]] || ROWS=24

LW=18                                     # left inner width (fixed)
RW=$(( COLS - LW - 3 ))                   # right inner width (adaptive)
[[ $RW -lt 30 ]] && RW=30

# Strip ANSI escapes then pad to width — $'\033' is the literal ESC char
pad() {
    local raw; raw=$(printf '%s' "$1" | sed $'s/\033\[[0-9;]*m//g')
    local p=$(( $2 - ${#raw} )); [[ $p -lt 0 ]] && p=0
    printf '%s%*s' "$1" "$p" ""
}

row() { printf "${BL}|${E}$(pad "$1" $LW)${BL}|${E}$(pad "$2" $RW)${BL}|${E}\n"; }

border() {
    local eq_l eq_r
    eq_l=$(printf '%*s' $LW  '' | tr ' ' '=')
    eq_r=$(printf '%*s' $RW  '' | tr ' ' '=')
    printf "${BL}+%s+%s+${E}\n" "$eq_l" "$eq_r"
}

# Separator line — exactly RW visible chars (3 spaces + dashes)
_make_sep() { printf '   %*s' $(( RW - 3 )) '' | tr ' ' '-'; }
SEP=$(_make_sep)

# Left column (20 rows, static)
declare -a L=(
    ""
    "  ${C}${B}ARKAOS${E}"
    "  ${D}--------------${E}"
    ""
    "  ${D}privacy-first${E}"
    "  ${D}linux${E}"
    ""
    "  ${G}*${E} composefs"
    "  ${G}*${E} DoT DNS"
    "  ${G}*${E} MAC random"
    "  ${G}*${E} IPv6 priv"
    "  ${G}*${E} bwrap"
    ""
    ""
    ""
    ""
    ""
    "  ${D}--------------${E}"
    "  ${D}Thulasiram K${E}"
    ""
)

draw_wide() {
    clear
    border
    local args=("$@")
    for i in "${!L[@]}"; do row "${L[$i]}" "${args[$i]:-}"; done
    border
}

draw_narrow() {
    # narrow: single-column, $1=title, rest=content lines
    clear
    local title="$1"; shift
    local w=$(( COLS - 2 ))
    local eq; eq=$(printf '%*s' $w '' | tr ' ' '=')
    printf "${BL}+%s+${E}\n" "$eq"
    printf "${BL}|${E}$(pad "  ${C}${B}ARKAOS${E}  ${D}--  %s${E}" $w)${BL}|${E}\n" "$title"
    printf "${BL}+%s+${E}\n" "$eq"
    for line in "$@"; do
        printf "${BL}|${E}$(pad "$line" $w)${BL}|${E}\n"
    done
    printf "${BL}+%s+${E}\n" "$eq"
}

draw_panel() {
    if [[ $COLS -ge 80 ]]; then draw_wide "$@"
    else draw_narrow "$@"; fi
}

spin_pid() {
    local pid=$1 msg="$2" fr='-\|/'
    while kill -0 "$pid" 2>/dev/null; do
        for i in 0 1 2 3; do
            printf "\r   ${C}${fr:$i:1}${E}  %s" "$msg"
            sleep 0.1
        done
    done
    wait "$pid" 2>/dev/null
    printf "\r   ${G}OK${E} %-56s\n" "$msg"
}
spin() { local msg="$1"; shift; "$@" &>/dev/null & spin_pid $! "$msg"; }

# ── Step 1: username ─────────────────────────────────────────────────────────
err=""
while true; do
    if [[ $COLS -ge 80 ]]; then
        draw_wide \
            "" \
            "   ${Y}ACCOUNT SETUP${E}                          ${D}1 / 3${E}" \
            "$SEP" \
            "" \
            "   Create a username for your account." \
            "   ${D}Lowercase letters, numbers, _ or -${E}" \
            "" "" "" "" "" "" "" "" "" "" "" "" "" \
            "   ${D}[*] [ ] [ ]${E}"
    else
        draw_narrow "ACCOUNT SETUP  1/3" \
            "" "   Create a username." \
            "   ${D}Lowercase, numbers, _ or -${E}" ""
    fi
    [[ -n "$err" ]] && printf "\n   ${R}! %s${E}\n" "$err" || printf "\n"
    printf "   Username  > "
    read -r username
    [[ "$username" =~ ^[a-z][a-z0-9_-]{0,30}$ ]] && { err=""; break; }
    err="start with a letter -- lowercase letters, numbers, _ or - only"
done

# ── Step 2: password ─────────────────────────────────────────────────────────
err=""
while true; do
    if [[ $COLS -ge 80 ]]; then
        draw_wide \
            "" \
            "   ${Y}ACCOUNT SETUP${E}                          ${D}2 / 3${E}" \
            "$SEP" \
            "" \
            "   Choose a password for  ${C}${username}${E}" \
            "   ${D}Minimum 8 characters${E}" \
            "" "" "" "" "" "" "" "" "" "" "" "" "" \
            "   ${D}[*] [*] [ ]${E}"
    else
        draw_narrow "ACCOUNT SETUP  2/3" \
            "" "   Password for ${C}${username}${E}" \
            "   ${D}Minimum 8 characters${E}" ""
    fi
    [[ -n "$err" ]] && printf "\n   ${R}! %s${E}\n" "$err" || printf "\n"
    printf "   Password  > "; read -rsp "" password; printf "\n"
    if [[ -z "$password" ]]; then err="password cannot be empty"; continue; fi
    if [[ ${#password} -lt 8 ]]; then err="password must be at least 8 characters"; continue; fi
    printf "   Confirm   > "; read -rsp "" confirm; printf "\n"
    [[ "$password" == "$confirm" ]] && { err=""; break; }
    err="passwords do not match -- try again"
done

# ── Step 3: autologin ────────────────────────────────────────────────────────
if [[ $COLS -ge 80 ]]; then
    draw_wide \
        "" \
        "   ${Y}PREFERENCES${E}                             ${D}3 / 3${E}" \
        "$SEP" \
        "" \
        "   ${B}Should ArkaOS log you in automatically on boot?${E}" \
        "" \
        "   ${G}Y  Autologin ON${E}" \
        "      Boots straight to your desktop. No password prompt." \
        "      ${D}Best for a personal laptop or single-user machine.${E}" \
        "" \
        "   ${R}N  Autologin OFF${E}" \
        "      Asks for your password on every boot." \
        "      ${D}Better if others have physical access to this machine.${E}" \
        "" \
        "   ${D}You can switch this on or off any time:${E}" \
        "   ${D}Open ArkaOS Settings with  Super+S  on the desktop.${E}" \
        "" "" "" \
        "   ${D}[*] [*] [*]${E}"
else
    draw_narrow "PREFERENCES  3/3" \
        "" \
        "   ${G}Y${E} = auto-login (no password prompt)" \
        "   ${R}N${E} = ask password each boot" \
        "   ${D}Change later: Super+S${E}" ""
fi
printf "\n   Autologin [Y/n] > "
read -r al_choice

# ── Configuring (show what makes ArkaOS different) ───────────────────────────
if [[ $COLS -ge 80 ]]; then
    draw_wide \
        "" \
        "   ${Y}CONFIGURING${E}" \
        "$SEP" \
        "" \
        "   ${D}What makes ArkaOS different from other Linux distros:${E}" \
        "" \
        "   ${G}*${E} ${B}Immutable rootfs${E}" \
        "     ${D}System files are read-only at runtime. Malware cannot${E}" \
        "     ${D}silently modify the OS between reboots.${E}" \
        "" \
        "   ${G}*${E} ${B}Encrypted DNS${E}" \
        "     ${D}Every DNS query goes over TLS to Quad9 (9.9.9.9:853).${E}" \
        "     ${D}Your ISP cannot see what sites you look up.${E}" \
        "" \
        "   ${G}*${E} ${B}MAC randomisation${E}" \
        "     ${D}Hardware address changes on every new connection.${E}" \
        "     ${D}Prevents tracking you across different networks.${E}" \
        "" \
        "   ${G}*${E} ${B}Browser sandbox${E}" \
        "     ${D}Firefox runs isolated. It cannot read your home folder,${E}" \
        "     ${D}WiFi passwords, or system configuration files.${E}"
else
    draw_narrow "CONFIGURING" "" "   Setting up your account..." ""
fi
printf "\n"

spin "Creating user account" useradd -m -G wheel,video,input -s /bin/bash "$username"

( printf '%s:%s\n' "$username" "$password" | chpasswd ) &>/dev/null &
spin_pid $! "Setting password"

if [[ "${al_choice,,}" != "n" ]]; then
    spin "Enabling autologin" bash -c "
        mkdir -p /etc/systemd/system/getty@tty1.service.d
        printf '[Service]\nExecStart=\nExecStart=-/sbin/agetty --autologin $username --noclear %%I \$TERM\n' \
            > /etc/systemd/system/getty@tty1.service.d/autologin.conf"
    al_note="${G}Autologin ON${E}  -- desktop loads automatically on boot"
else
    spin "Configuring login prompt" bash -c "
        mkdir -p /etc/systemd/system/getty@tty1.service.d
        printf '[Service]\nExecStart=\nExecStart=-/sbin/agetty --noclear -n -o $username %%I \$TERM\n' \
            > /etc/systemd/system/getty@tty1.service.d/prefill.conf"
    al_note="${Y}Autologin OFF${E} -- login prompt will ask only for your password"
fi

spin "Finalising" touch /var/lib/arkaos-firstboot-done

# ── Welcome ──────────────────────────────────────────────────────────────────
if [[ $COLS -ge 80 ]]; then
    draw_wide \
        "" \
        "   ${G}${B}ALL DONE!${E}  Welcome, ${C}${username}${E}" \
        "$SEP" \
        "" \
        "   $al_note" \
        "" \
        "   ${D}Desktop shortcuts${E}" \
        "   ${BL}Super+Enter${E}   open terminal" \
        "   ${BL}Super+Space${E}   app launcher" \
        "   ${BL}Super+B${E}       Firefox  ${D}(sandboxed)${E}" \
        "   ${BL}Super+E${E}       file manager" \
        "   ${BL}Super+S${E}       ArkaOS settings" \
        "   ${BL}Super+1-9${E}     switch workspace" \
        "" "" "" "" "" "" ""
else
    draw_narrow "ALL DONE! Welcome, ${C}${username}${E}" \
        "" "   $al_note" "" \
        "   Super+Enter  terminal" \
        "   Super+B      browser" \
        "   Super+S      settings" ""
fi
printf "\n   ${Y}Rebooting into your desktop in 5 seconds...${E}\n\n"
sleep 5
systemctl reboot
