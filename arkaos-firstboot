#!/bin/bash
exec </dev/tty1 >/dev/tty1 2>&1

B='\033[1m'
C='\033[1;36m'
BL='\033[1;34m'
G='\033[1;32m'
Y='\033[1;33m'
R='\033[1;31m'
D='\033[2m'
E='\033[0m'

spinner() {
    local msg="$1"
    local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    for _ in $(seq 1 20); do
        for i in $(seq 0 9); do
            printf "\r    ${C}${frames:$i:1}${E}  %s..." "$msg"
            sleep 0.05
        done
    done
    printf "\r    ${G}✓${E}  %-36s\n" "$msg"
}

clear
printf '\n\n'
printf "${C}"
printf '    ░█████╗░██████╗░██╗░░██╗░█████╗░░█████╗░░██████╗\n'
printf '    ██╔══██╗██╔══██╗██║░██╔╝██╔══██╗██╔══██╗██╔════╝\n'
printf '    ███████║██████╔╝█████╔╝░███████║██║░░██║╚█████╗░\n'
printf '    ██╔══██║██╔══██╗██╔═██╗░██╔══██║██║░░██║░╚═══██╗\n'
printf '    ██║░░██║██║░░██║██║░╚██╗██║░░██║╚█████╔╝██████╔╝\n'
printf '    ╚═╝░░╚═╝╚═╝░░╚═╝╚═╝░░╚═╝╚═╝░░╚═╝░╚════╝░╚═════╝\n'
printf "${E}\n"
printf "    ${BL}┌─────────────────────────────────────────────────┐${E}\n"
printf "    ${BL}│${E}  ${B}Privacy-first immutable desktop Linux${E}            ${BL}│${E}\n"
printf "    ${BL}│${E}  ${D}Secure by design. Built on bootc + composefs.${E}    ${BL}│${E}\n"
printf "    ${BL}└─────────────────────────────────────────────────┘${E}\n\n"
printf "    ${D}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${E}\n"
printf "    ${Y}FIRST BOOT SETUP${E}  ${D}Create your account${E}\n"
printf "    ${D}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${E}\n\n"

while true; do
    printf "    ${C}▸${E} ${B}Username:${E} "
    read -r username
    if [[ "$username" =~ ^[a-z][a-z0-9_-]{0,30}$ ]]; then
        printf "    ${G}  ✓ Username accepted${E}\n\n"
        break
    fi
    printf "    ${R}  ✗ Lowercase letters/numbers/_ only, must start with a letter${E}\n\n"
done

while true; do
    printf "    ${C}▸${E} ${B}Password:${E} "
    read -rsp "" password; printf '\n'
    if [[ -z "$password" ]]; then
        printf "    ${R}  ✗ Password cannot be empty${E}\n\n"
        continue
    fi
    printf "    ${C}▸${E} ${B}Confirm: ${E} "
    read -rsp "" confirm; printf '\n'
    if [[ "$password" == "$confirm" ]]; then
        printf "    ${G}  ✓ Password set${E}\n\n"
        break
    fi
    printf "    ${R}  ✗ Passwords do not match — try again${E}\n\n"
done

printf "    ${D}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${E}\n"
printf "    ${Y}CONFIGURING YOUR SYSTEM${E}\n\n"

useradd -m -G wheel -s /bin/bash "$username" 2>/dev/null
spinner "Creating user account"

printf '%s:%s' "$username" "$password" | chpasswd 2>/dev/null
spinner "Setting credentials"

mkdir -p /etc/systemd/system/getty@tty1.service.d
printf '[Service]\nExecStart=\nExecStart=-/sbin/agetty --autologin %s --noclear %%I $TERM\n' \
    "$username" > /etc/systemd/system/getty@tty1.service.d/autologin.conf
spinner "Enabling autologin for $username"

touch /var/lib/arkaos-firstboot-done
spinner "Finalizing setup"

printf '\n'
printf "    ${D}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${E}\n"
printf "    ${G}${B}All done!${E}  Welcome aboard, ${C}${username}${E}.\n\n"

printf "    ${D}Your Hyprland desktop shortcuts:${E}\n"
printf "    ${BL}  Super + Enter${E}    open terminal\n"
printf "    ${BL}  Super + B${E}        launch Firefox  ${D}(sandboxed)${E}\n"
printf "    ${BL}  Super + 1-9${E}      switch workspace\n"
printf "    ${BL}  Super+Shift+Q${E}    close window\n\n"

printf "    ${D}Privacy protections active on every boot:${E}\n"
printf "    ${C}  •${E} MAC randomisation  ${D}(WiFi + ethernet)${E}\n"
printf "    ${C}  •${E} DNS-over-TLS       ${D}(Quad9 — 9.9.9.9)${E}\n"
printf "    ${C}  •${E} IPv6 privacy extensions\n"
printf "    ${C}  •${E} Firefox in bubblewrap sandbox\n\n"

printf "    ${D}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${E}\n"
printf "    ${Y}⟳  Rebooting into your desktop in 5 seconds...${E}\n\n"
sleep 5
systemctl reboot
