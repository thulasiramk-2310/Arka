#!/bin/bash
# ArkaOS: apply the branded wallpaper + accent on first Plasma login, then
# disable this autostart entry. The dark color scheme is already preset via
# /etc/skel/.config/kdeglobals, so this only handles what needs the running
# Plasma session (the official plasma-apply-* tools talk to plasmashell).

# Give plasmashell a moment to be ready for the apply tools.
sleep 3

# In a VM the virtual display often defaults to 640x480; bump it to a usable
# size by resolving the mode ID for a comfortable resolution. No-op on real
# hardware (the output name won't match Virtual-*).
VOUT=$(kscreen-doctor -o 2>/dev/null | grep -oE 'Virtual-[0-9]+' | head -1)
if [ -n "$VOUT" ]; then
    INFO=$(kscreen-doctor -o 2>/dev/null)
    for RES in 1440x900 1600x900 1280x800 1280x720 1024x768; do
        MID=$(printf '%s' "$INFO" | grep -oE "[0-9]+:${RES}@" | head -1 | cut -d: -f1)
        if [ -n "$MID" ]; then
            kscreen-doctor "output.$VOUT.mode.$MID" 2>/dev/null && { sleep 1; break; }
        fi
    done
fi

WALL=/usr/share/arka/wallpapers/default.png

# Apply the ArkaOS color scheme + green #16C784 accent (harmless if already
# set from skel), then the wallpaper.
plasma-apply-colorscheme ArkaOS 2>/dev/null || true
[ -x "$(command -v kwriteconfig6)" ] && {
    kwriteconfig6 --file kdeglobals --group General --key AccentColor "22,199,132"
    kwriteconfig6 --file kdeglobals --group General --key accentColorFromWallpaper false
}
[ -f "$WALL" ] && plasma-apply-wallpaperimage "$WALL" 2>/dev/null || true

# Reshape the desktop toward the ArkaOS layout (top bar + floating dock +
# full-screen launcher) via Plasma's scripting API.
LAYOUT=/usr/share/arka/arka-layout.js
if [ -f "$LAYOUT" ]; then
    dbus-send --session --type=method_call --dest=org.kde.plasmashell \
        /PlasmaShell org.kde.PlasmaShell.evaluateScript \
        string:"$(cat "$LAYOUT")" 2>/dev/null || true
fi

# One-shot: remove the autostart entry so this never runs again.
rm -f "$HOME/.config/autostart/arka-plasma-firstrun.desktop"
