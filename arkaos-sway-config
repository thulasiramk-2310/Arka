# ArkaOS sway config — minimal, keyboard-driven
set $mod Mod4

font pango:monospace 10

# Applications
bindsym $mod+Return exec foot
bindsym $mod+b      exec firefox
bindsym $mod+Shift+q kill
bindsym $mod+Shift+c reload

# Focus
bindsym $mod+Left  focus left
bindsym $mod+Right focus right
bindsym $mod+Up    focus up
bindsym $mod+Down  focus down

# Move windows
bindsym $mod+Shift+Left  move left
bindsym $mod+Shift+Right move right
bindsym $mod+Shift+Up    move up
bindsym $mod+Shift+Down  move down

# Layout toggle
bindsym $mod+v layout toggle split

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3

# Appearance — set explicit mode for virtio-vga virtual display
output * mode 1920x1080
output * bg #0f0f14 solid_color
default_border pixel 2
gaps inner 4
client.focused #1a3a5c #1a3a5c #ffffff #1a3a5c

# Status bar
bar {
    position top
    status_command while date +'%H:%M   %Y-%m-%d'; do sleep 1; done
    colors {
        background #0f0f14
        statusline #cccccc
        focused_workspace   #0f0f14 #1a3a5c #ffffff
        inactive_workspace  #0f0f14 #0f0f14 #666666
    }
}

# Input
input "type:keyboard" {
    repeat_delay 300
    repeat_rate 40
}
input "type:pointer" {
    accel_profile flat
}
