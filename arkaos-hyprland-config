# ArkaOS Hyprland config

# Monitor — auto-detect preferred resolution (works for QEMU virtio-vga and real hardware)
monitor=,preferred,auto,1

# Startup
exec-once = sh -c 'WP=$(cat ~/.config/arkaos/wallpaper 2>/dev/null); swaybg -i "${WP:-/usr/share/arka/wallpapers/default.png}" -m fill'
exec-once = arka-bar
exec-once = arka-dock
exec-once = mako
exec-once = arka-welcome

# Environment
env = WLR_NO_HARDWARE_CURSORS,1
env = WLR_RENDERER_ALLOW_SOFTWARE,1
env = MOZ_ENABLE_WAYLAND,1
env = GDK_BACKEND,wayland
env = XCURSOR_SIZE,24
env = GSK_RENDERER,cairo
env = GTK_A11Y,none

# Input
input {
    kb_layout = us
    follow_mouse = 1
    sensitivity = 0
    touchpad {
        natural_scroll = false
    }
}

# General
general {
    gaps_in = 6
    gaps_out = 12
    border_size = 1
    col.active_border = rgba(3a3a42ff)
    col.inactive_border = rgba(1f1f23ff)
    layout = dwindle
    resize_on_border = true
}

# Decoration
decoration {
    rounding = 8
    active_opacity = 1.0
    inactive_opacity = 0.95
    blur {
        enabled = false
    }
    shadow {
        enabled = true
        range = 8
        render_power = 2
        color = rgba(00000088)
    }
}

# Animations
animations {
    enabled = true
    bezier = overshot, 0.05, 0.9, 0.1, 1.1
    animation = windows,    1, 5, overshot, slide
    animation = windowsOut, 1, 4, default,  popin 80%
    animation = border,     1, 8, default
    animation = fade,       1, 6, default
    animation = workspaces, 1, 5, overshot, slidevert
}

# Layout
dwindle {
    pseudotile = true
    preserve_split = true
}

# Floating windows
windowrulev2 = float,  class:^(org.arka.settings)$
windowrulev2 = size  720 680, class:^(org.arka.settings)$
windowrulev2 = center, class:^(org.arka.settings)$

windowrulev2 = float,  class:^(org.arka.dashboard)$
windowrulev2 = size  760 700, class:^(org.arka.dashboard)$
windowrulev2 = center, class:^(org.arka.dashboard)$

windowrulev2 = float,    class:^(org.arka.launcher)$
windowrulev2 = noanim,   class:^(org.arka.launcher)$
windowrulev2 = noborder, class:^(org.arka.launcher)$

windowrulev2 = float,  class:^(org.arka.wifi)$
windowrulev2 = size  440 520, class:^(org.arka.wifi)$
windowrulev2 = center, class:^(org.arka.wifi)$

windowrulev2 = float,  class:^(org.arka.update)$
windowrulev2 = size  460 400, class:^(org.arka.update)$
windowrulev2 = center, class:^(org.arka.update)$

windowrulev2 = float,  class:^(org.arka.hotkeys)$
windowrulev2 = size  500 580, class:^(org.arka.hotkeys)$
windowrulev2 = center, class:^(org.arka.hotkeys)$

windowrulev2 = float,  class:^(org.arka.perms)$
windowrulev2 = size  640 700, class:^(org.arka.perms)$
windowrulev2 = center, class:^(org.arka.perms)$

windowrulev2 = float,  class:^(org.arka.welcome)$
windowrulev2 = size  680 640, class:^(org.arka.welcome)$
windowrulev2 = center, class:^(org.arka.welcome)$

windowrulev2 = float,  class:^(org.arka.sound)$
windowrulev2 = size  300 240, class:^(org.arka.sound)$
windowrulev2 = move  onscreen cursor -150 40, class:^(org.arka.sound)$

windowrulev2 = float,  class:^(org.arka.bluetooth)$
windowrulev2 = size  420 500, class:^(org.arka.bluetooth)$
windowrulev2 = center, class:^(org.arka.bluetooth)$

windowrulev2 = float,  class:^(org.arka.capsule)$
windowrulev2 = size  720 640, class:^(org.arka.capsule)$
windowrulev2 = center, class:^(org.arka.capsule)$

# User apps float like a normal desktop (not tiled fullscreen)
windowrulev2 = float,  class:^(foot)$
windowrulev2 = size  780 480, class:^(foot)$
windowrulev2 = center, class:^(foot)$

windowrulev2 = float,  class:^(thunar)$
windowrulev2 = size  820 560, class:^(thunar)$
windowrulev2 = center, class:^(thunar)$

# Keybinds
$mod = SUPER
bind = $mod,       Return,    exec,  foot
bind = $mod,       B,         exec,  firefox
bind = $mod,       Space,     exec,  arka-launcher
bind = $mod,       E,         exec,  thunar
bind = $mod,       S,         exec,  arka-settings-gtk
bind = $mod,       D,         exec,  arka-dashboard
bind = $mod,       W,         exec,  arka-wifi
bind = $mod,       U,         exec,  arka-update
bind = $mod,       slash,     exec,  arka-hotkeys
bind = $mod,       P,         exec,  arka-capsule
bind = $mod,       M,         exec,  arka-perms
bind = $mod,       N,         exec,  arka-sound
bind = $mod,       T,         exec,  arka-bluetooth
bind = $mod,       L,         exec,  swaylock
bind = $mod SHIFT, Q,         killactive
bind = ALT,        F4,        killactive
bind = $mod SHIFT, E,         exit
bind = $mod,       F,         fullscreen

# Screenshots
bind  = ,          Print,     exec,  sh -c 'mkdir -p ~/Pictures && grim ~/Pictures/screenshot-$(date +%s).png && notify-send "Screenshot" "Saved to ~/Pictures"'
bind  = $mod SHIFT,S,         exec,  sh -c 'mkdir -p ~/Pictures && grim -g "$(slurp)" ~/Pictures/screenshot-$(date +%s).png && notify-send "Screenshot" "Saved to ~/Pictures"'

# Volume (media keys — XF86 works regardless of which Fn key the laptop assigns)
bindel = ,XF86AudioRaiseVolume,  exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindel = ,XF86AudioLowerVolume,  exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bind   = ,XF86AudioMute,         exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bind   = ,XF86AudioMicMute,      exec, wpctl set-mute @DEFAULT_SOURCE@ toggle

# Screen brightness (media keys)
bindel = ,XF86MonBrightnessUp,   exec, brightnessctl set 10%+
bindel = ,XF86MonBrightnessDown, exec, brightnessctl set 10%-

# Focus
bind = $mod, left,  movefocus, l
bind = $mod, right, movefocus, r
bind = $mod, up,    movefocus, u
bind = $mod, down,  movefocus, d

# Move windows
bind = $mod SHIFT, left,  movewindow, l
bind = $mod SHIFT, right, movewindow, r
bind = $mod SHIFT, up,    movewindow, u
bind = $mod SHIFT, down,  movewindow, d

# Workspaces
bind = $mod,       1, workspace,       1
bind = $mod,       2, workspace,       2
bind = $mod,       3, workspace,       3
bind = $mod SHIFT, 1, movetoworkspace, 1
bind = $mod SHIFT, 2, movetoworkspace, 2
bind = $mod SHIFT, 3, movetoworkspace, 3

# Mouse
bindm = $mod, mouse:272, movewindow
bindm = $mod, mouse:273, resizewindow
